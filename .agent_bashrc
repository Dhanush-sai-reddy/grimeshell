# ============================================================================
# SHELLLL — Agent Shell Environment
# Source this file from bash or zsh to activate the agent environment.
#   source /home/dhanushsr/Downloads/mygit/SHELLLL/.agent_bashrc
# ============================================================================

# --- Guard against double-sourcing -----------------------------------------
if [ -n "${SHELLLL_LOADED:-}" ]; then
    return 0 2>/dev/null || exit 0
fi

# --- Core Variables --------------------------------------------------------
export SHELLLL_ROOT="/home/dhanushsr/Downloads/mygit/SHELLLL"
export SHELLLL_LOADED=1

# --- API Keys --------------------------------------------------------------
# Keys are loaded from:
#   1. keys/<name>  (plain text files, gitignored)
#   2. .env         (gitignored, overrides keys/ if both set)
# Never hardcode keys here — add them to keys/ or .env instead.

# Load a key from keys/ into an env var (silently skips if file missing)
_load_key() {
    local var="$1"
    local file="$SHELLLL_ROOT/keys/$2"
    if [[ -f "$file" ]] && [[ -z "${!var:-}" ]]; then
        export "$var"="$(tr -d '[:space:]' < "$file")"
    fi
}

# Auto-load from keys/ folder
_load_key HF_TOKEN           hf_token
_load_key HUGGINGFACE_TOKEN  hf_token
_load_key HF_API_TOKEN       hf_token
_load_key GEMINI_API_KEY     gemini_api_key
_load_key ANTHROPIC_API_KEY  anthropic_api_key
_load_key OPENAI_API_KEY     openai_api_key
_load_key BRAVE_API_KEY      brave_api_key
_load_key TAVILY_API_KEY     tavily_api_key
_load_key NEO4J_PASSWORD     neo4j_password
_load_key QDRANT_API_KEY     qdrant_api_key
_load_key VLLM_API_KEY       vllm_api_key

# Also source .env if it exists (values here override keys/ since shell already has them exported)
if [[ -f "$SHELLLL_ROOT/.env" ]]; then
    set -a
    # shellcheck disable=SC1090
    source "$SHELLLL_ROOT/.env"
    set +a
fi

# --- PATH Additions -------------------------------------------------------
# Local binaries, npm globals, SHELLLL scripts
_shellll_prepend_path() {
    case ":${PATH}:" in
        *:"$1":*) ;;          # Already in PATH
        *) export PATH="$1:$PATH" ;;
    esac
}

_shellll_prepend_path "$SHELLLL_ROOT/node_modules/.bin"
_shellll_prepend_path "$SHELLLL_ROOT/scripts"
_shellll_prepend_path "$HOME/.local/bin"
_shellll_prepend_path "$HOME/.npm-global/bin"
_shellll_prepend_path "$HOME/.cargo/bin"

# --- Editor ----------------------------------------------------------------
export EDITOR="${EDITOR:-nvim}"
export VISUAL="${VISUAL:-$EDITOR}"

# --- vLLM Local Engine -----------------------------------------------------
export VLLM_BASE_URL="${VLLM_BASE_URL:-http://localhost:8000/v1}"
export VLLM_PORT="${VLLM_PORT:-8000}"
export VLLM_MODEL="${VLLM_MODEL:-Qwen/Qwen2.5-7B-Instruct}"
export VLLM_API_KEY="${VLLM_API_KEY:-not-needed}"

# --- Agent Identity --------------------------------------------------------
export AGENT_NAME="${AGENT_NAME:-shellll-agent}"
export AGENT_SESSION_ID="${AGENT_SESSION_ID:-session_$(date +%Y%m%d_%H%M%S)_$$}"
export AGENT_BRAIN="$SHELLLL_ROOT/Agent.md"

# --- Projects Root ---------------------------------------------------------
export PROJECTS_ROOT="/home/dhanushsr/Downloads/mygit"

# --- Aliases ---------------------------------------------------------------
# Core SHELLLL commands
alias smell='bash "$SHELLLL_ROOT/scripts/smell.sh"'
alias compact='bash "$SHELLLL_ROOT/scripts/context-compact.sh"'
alias clear-ctx='bash "$SHELLLL_ROOT/scripts/context-clear.sh"'
alias agent-launch='bash "$SHELLLL_ROOT/scripts/agent-launch.sh"'
alias agent-sandbox='bash "$SHELLLL_ROOT/scripts/agent-sandbox.sh"'
alias ksync='bash "$SHELLLL_ROOT/scripts/knowledge-sync.sh"'

# Quick navigation
alias brain='cd "$SHELLLL_ROOT"'
alias projects='cd "$PROJECTS_ROOT"'
alias knowledge='cd "$SHELLLL_ROOT/knowledge"'

# Git shortcuts (agent-friendly)
alias gs='git status --short --branch'
alias gl='git log --oneline --graph -20'
alias gd='git diff --stat'
alias ga='git add -A'
alias gc='git commit'
alias gp='git push'

# vLLM server management
alias vllm-start='_vllm_start'
alias vllm-stop='tmux kill-session -t vllm-server 2>/dev/null && echo "[vLLM] server stopped" || echo "[vLLM] no running session found"'
alias vllm-status='curl -sf "${VLLM_BASE_URL%/v1}/health" && echo " [vLLM] server healthy" || echo "[vLLM] server not reachable at ${VLLM_BASE_URL}"'
alias vllm-models='curl -sf "${VLLM_BASE_URL}/models" | jq -r ".data[].id" 2>/dev/null || echo "[vLLM] server not reachable"'

# Utility
alias ll='lsd -la --group-directories-first 2>/dev/null || ls -la --color=auto'
alias lt='lsd --tree --depth 3 2>/dev/null || tree -L 3'
alias cat='bat --paging=never 2>/dev/null || cat'

# --- Functions -------------------------------------------------------------

# Quick status of the SHELLLL brain
shellll_status() {
    echo "╭─────────────────────────────────────╮"
    echo "│        SHELLLL Agent Status         │"
    echo "╰─────────────────────────────────────╯"
    echo "  Agent:     $AGENT_NAME"
    echo "  Session:   $AGENT_SESSION_ID"
    echo "  Root:      $SHELLLL_ROOT"
    echo "  Shell:     ${SHELL##*/}"
    echo "  Editor:    $EDITOR"
    echo ""
    if [ -d "$SHELLLL_ROOT/.git" ]; then
        echo "  Git branch: $(git -C "$SHELLLL_ROOT" branch --show-current 2>/dev/null || echo 'N/A')"
        echo "  Git status: $(git -C "$SHELLLL_ROOT" status --short 2>/dev/null | wc -l) changed files"
    fi
    echo ""
}

# Auto-source agent env when creating tmux sessions
# Usage: agent_tmux <session-name>
agent_tmux() {
    local session_name="${1:-agent}"
    tmux new-session -d -s "$session_name" 2>/dev/null || true
    tmux send-keys -t "$session_name" "source '$SHELLLL_ROOT/.agent_bashrc' && shellll_status" Enter
    tmux attach-session -t "$session_name"
}

# Quick search across knowledge base
knowledge_search() {
    local query="${1:?Usage: knowledge_search <query>}"
    grep -rni --color=always "$query" "$SHELLLL_ROOT/knowledge/" 2>/dev/null || echo "No results found."
}

# Start vLLM server in a dedicated tmux session
_vllm_start() {
    local model="${1:-$VLLM_MODEL}"
    local port="${VLLM_PORT:-8000}"
    local api_key="${VLLM_API_KEY:-not-needed}"
    local venv="$HOME/.venvs/vllm"

    if tmux has-session -t vllm-server 2>/dev/null; then
        echo "[vLLM] session 'vllm-server' already running. Use: tmux attach -t vllm-server"
        return 0
    fi

    echo "[vLLM] starting server for model: $model (port $port)"
    tmux new-session -d -s vllm-server
    # Activate venv if present, else use system python
    if [[ -f "$venv/bin/activate" ]]; then
        tmux send-keys -t vllm-server "source '$venv/bin/activate'" Enter
    fi
    tmux send-keys -t vllm-server \
        "vllm serve '$model' --host 0.0.0.0 --port $port --api-key '$api_key' --dtype auto" Enter
    echo "[vLLM] server launching in tmux session 'vllm-server'"
    echo "[vLLM] attach with:  tmux attach -t vllm-server"
    echo "[vLLM] health check: vllm-status"
}

# Read the brain (Agent.md)
read_brain() {
    if command -v bat &>/dev/null; then
        bat --paging=never "$SHELLLL_ROOT/Agent.md"
    else
        cat "$SHELLLL_ROOT/Agent.md"
    fi
}

# --- Startup Message -------------------------------------------------------
# Only show in interactive shells
case "$-" in
    *i*)
        printf '\033[0;36m[SHELLLL]\033[0m Agent environment loaded — %s @ %s\n' \
            "$AGENT_NAME" "$(date +%H:%M:%S)"
        ;;
esac
